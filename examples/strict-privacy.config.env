# Strict privacy mode.
# Use this when privacy matters more than false positives and reviewer latency.
LLMVEIL_HOME=~/.llmveil
LLMVEIL_UPSTREAM_BASE_URL=https://relay.example.invalid/v1
LLMVEIL_UPSTREAM_PROTOCOL=openai
LLMVEIL_UPSTREAM_API_KEY_ENV=UPSTREAM_API_KEY_VALUE
LLMVEIL_PROFILE=strict
LLMVEIL_REDACTION_MODE=strict
LLMVEIL_OUTPUT_POLICY=block-all
# Copy examples/reviewers.example.json to ~/llmveil-reviewers.json, edit it, test it,
# then uncomment the next line.
# LLMVEIL_REVIEWERS_FILE=~/llmveil-reviewers.json
LLMVEIL_REDACT_WALLET_KEYS=on
LLMVEIL_MAX_UPSTREAM_RESPONSE_BYTES=16777216
LLMVEIL_METRICS=on
LLMVEIL_ACCESS_LOG=off
