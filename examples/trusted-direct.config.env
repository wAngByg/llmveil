# Trusted endpoint direct mode.
# Use this when you call an endpoint you trust and only want lightweight local redaction.
LLMVEIL_HOME=~/.llmveil
LLMVEIL_UPSTREAM_BASE_URL=https://api.example.invalid/v1
LLMVEIL_UPSTREAM_PROTOCOL=openai
LLMVEIL_UPSTREAM_API_KEY_ENV=UPSTREAM_API_KEY_VALUE
LLMVEIL_PROFILE=balanced
LLMVEIL_REDACTION_MODE=balanced
LLMVEIL_OUTPUT_POLICY=off
LLMVEIL_REDACT_WALLET_KEYS=off
LLMVEIL_MAX_UPSTREAM_RESPONSE_BYTES=16777216
LLMVEIL_METRICS=on
LLMVEIL_ACCESS_LOG=off
